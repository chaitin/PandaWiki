    "dev": "npm run dev --workspace=panda-wiki-app && npm run dev --workspace=panda-wiki-admin"
  },
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx,css,scss,md,mdx,json,yml,yaml,mjs,cjs}": "prettier --write --ignore-path .prettierignore"
