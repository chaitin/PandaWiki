    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.2",
    "@mui/material": "^7.3.2",
    "@panda-wiki/icons": "*",
    "@panda-wiki/themes": "*",
    "@panda-wiki/ui": "*",
    "dayjs": "^1.11.18",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-hook-form": "^7.62.0"
  },
  "devDependencies": {
    "@types/node": "^24.3.1",
